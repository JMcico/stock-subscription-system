# Copy to .env and adjust. When POSTGRES_DB is set, Django uses PostgreSQL; otherwise SQLite.
# POSTGRES_DB=stock_subscription
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Yahoo / yfinance
# YFINANCE_MOCK=0
# PRICE_CACHE_TTL=120

# OpenAI (Phase D — demo signals, not financial advice)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Email (dev: console backend)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DEFAULT_FROM_EMAIL=noreply@stock-subscription.local
