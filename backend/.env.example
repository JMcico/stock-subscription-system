# Copy to .env and adjust. When POSTGRES_DB is set, Django uses PostgreSQL; otherwise SQLite.

# Django core signing key (required)
# SECRET_KEY=replace_with_a_long_random_secret

# Redis: cache DB 1, Django-Q broker DB 2 (defaults match settings.py)
# REDIS_CACHE_URL=redis://127.0.0.1:6379/1
# REDIS_Q_URL=redis://127.0.0.1:6379/2
# REDIS_Q_HOST=127.0.0.1
# REDIS_Q_PORT=6379
# REDIS_Q_DB=2
# REDIS_Q_PASSWORD=

# POSTGRES_DB=stock_subscription
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Yahoo / yfinance
# YFINANCE_MOCK=0
# PRICE_CACHE_TTL=120

# OpenAI (Phase D — demo signals, not financial advice)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Email (production via Gmail SMTP)
# USE_GMAIL_SMTP=1
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=your_gmail@gmail.com
# EMAIL_HOST_PASSWORD=your_google_app_password
# DEFAULT_FROM_EMAIL=your_gmail@gmail.com
#
# Email (dev fallback)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
